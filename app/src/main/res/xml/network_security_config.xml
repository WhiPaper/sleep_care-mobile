<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <domain-config>
        <domain includeSubdomains="true">sleepcare-pi.local</domain>
        <trust-anchors>
            <!-- Trust SleepCare CA certificate for WSS connections -->
            <certificates src="@raw/pi_cert"/>
        </trust-anchors>
    </domain-config>
</network-security-config>
